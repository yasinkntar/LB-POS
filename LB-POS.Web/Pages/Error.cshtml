@page
@model ErrorModel
@{
    ViewData["Title"] = "حدث خطأ";
    var message = Request.Query["message"].ToString() ?? "حدث خطأ غير متوقع";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card border-0 shadow-lg rounded-4 p-5">
                <div class="mb-4">
                    <i class="fas fa-exclamation-triangle text-danger" style="font-size: 4rem;"></i>
                </div>
                <h2 class="fw-bold text-dark">عذراً! حدث خطأ ما</h2>
                <p class="text-muted mt-3">@message</p>
                
                <div class="mt-4">
                    <a href="/" class="btn btn-primary px-5 rounded-pill">العودة للرئيسية</a>
                    <button onclick="history.back()" class="btn btn-outline-secondary px-5 rounded-pill ms-2">الرجوع</button>
                </div>
            </div>
        </div>
    </div>
</div>