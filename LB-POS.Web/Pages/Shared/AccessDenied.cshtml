@page
@model LB_POS.Web.Pages.Shared.AccessDeniedModel
@{
    ViewData["Title"] = "وصول غير مسموح";
}

<div class="container" style="margin-top: 100px;">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="mb-4">
                <i class="bi bi-shield-lock-fill text-danger" style="font-size: 6rem;"></i>
            </div>
            
            <h1 class="display-4 fw-bold text-dark">403 - وصول غير مسموح</h1>
            <p class="lead text-muted mt-3">
                عذراً، ليس لديك الصلاحيات الكافية للوصول إلى هذه الصفحة أو تنفيذ هذا الإجراء.
            </p>
            
            <hr class="my-4" style="width: 50%; margin: auto;">

            <p class="mb-4">
                إذا كنت تعتقد أنك يجب أن تمتلك صلاحية الوصول، يرجى التواصل مع <strong>مدير النظام</strong> لتحديث إعدادات حسابك.
            </p>

            <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                <a href="/" class="btn btn-primary btn-lg px-4 gap-3">
                    <i class="bi bi-house-door"></i> العودة للرئيسية
                </a>
                <button onclick="history.back()" class="btn btn-outline-secondary btn-lg px-4">
                    <i class="bi bi-arrow-left"></i> الرجوع للخلف
                </button>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
}
