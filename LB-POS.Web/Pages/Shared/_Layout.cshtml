@using System.Security.Claims
@using Microsoft.Extensions.Localization
@using Microsoft.AspNetCore.Http
@using LB_POS.Core.Resources
@using LB_POS.Core.Extensions

@inject IStringLocalizer<SharedResources> L
@inject IHttpContextAccessor HttpContextAccessor

@{
    // منطق تحديد الصفحة النشطة
    bool IsActivePage(string url)
    {
        if (string.IsNullOrEmpty(url)) return false;
        var path = Context.Request.Path.ToString().TrimEnd('/');
        var target = url.TrimEnd('/');
        return string.Equals(path, target, StringComparison.OrdinalIgnoreCase) ||
               path.StartsWith(target + "/", StringComparison.OrdinalIgnoreCase);
    }

    var displayName = User.FindFirstValue(ClaimTypes.GivenName) ??
                  User.FindFirstValue(ClaimTypes.Name) ??
                  User.Identity?.Name ?? "المستخدم";

    var culture = System.Globalization.CultureInfo.CurrentUICulture.Name;
    var isRtl = culture.StartsWith("ar");

    // جلب القائمة المفلترة بناءً على الصلاحيات
    var menu = MenuBuilder.GetMenuItems();
    var filteredMenu = MenuService.FilterMenu(menu, HttpContextAccessor.HttpContext.User);
}

<!DOCTYPE html>
<html lang="@culture" dir="@(isRtl ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - POS_LB</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    @if (isRtl)
    {
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" />
    }
    else
    {
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    }
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>

<body class="app">

    <nav class="navbar topbar sticky-top bg-white border-bottom shadow-sm">
        <div class="container-fluid px-3">
            
            <div class="d-flex align-items-center">
                <button class="btn btn-light d-lg-none me-2 ms-2" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarOffcanvas">
                    <i class="fas fa-bars"></i>
                </button>

                <a class="navbar-brand fw-bold text-primary d-flex align-items-center" asp-page="/Index">
                    <img src="~/images/logo.png"
                         alt="Company Logo"
                         class="me-2 ms-2"
                         style="height: 40px; width: auto; object-fit: contain;" />
    
                    @* <span class="d-none d-sm-inline">POS_LB</span> *@
                </a>
            </div>

            <div class="ms-auto d-flex align-items-center gap-2 gap-md-3">
                <div class="dropdown">
                    <button class="btn btn-light dropdown-toggle btn-sm" data-bs-toggle="dropdown">
                        <i class="fas fa-globe me-1 ms-1"></i>
                        <span class="d-none d-sm-inline">@(isRtl ? "العربية" : "English")</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item @(isRtl ? "active" : "")" href="#" onclick="setLanguage('ar-EG')">العربية</a></li>
                        <li><a class="dropdown-item @(!isRtl ? "active" : "")" href="#" onclick="setLanguage('en-US')">English</a></li>
                    </ul>
                </div>

                <button class="btn btn-light btn-sm" id="themeToggle">
                    <i class="fas fa-moon"></i>
                </button>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="dropdown">
                        <button class="btn btn-light btn-sm dropdown-toggle d-flex align-items-center gap-2" data-bs-toggle="dropdown">
                            <i class="fas fa-user-circle text-primary fs-5"></i>
                            <span class="d-none d-md-inline">@displayName</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                            <li class="dropdown-header text-center p-3">
                                <i class="fas fa-user-circle fa-3x text-primary mb-2"></i>
                                <div class="fw-bold">@displayName</div>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="/Settings"><i class="fas fa-cog me-2 ms-2"></i> @L["Settings"]</a></li>
                            <li>
                                <form method="post" action="/logout">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item text-danger"><i class="fas fa-sign-out-alt me-2 ms-2"></i> @L["Logout"]</button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
            </div>
        </div>
    </nav>

    <div class="app-body d-flex">

        <aside class="sidebar d-none d-lg-block border-end bg-light">
            <div class="sidebar-wrapper p-3">
                @* <div class="small text-muted mb-3 text-uppercase fw-bold" style="font-size: 0.7rem;">@L["Main Menu"]</div> *@
                
                <ul class="nav nav-pills flex-column gap-1">
                    @foreach (var item in filteredMenu)
                    {
                        var collapseId = "menu_" + Math.Abs(item.Title.GetHashCode());
                        var isParentActive = item.Children.Any(c => IsActivePage(c.Url));

                        if (item.Children.Any())
                        {
                            <li class="nav-item">
                                <a class="nav-link d-flex justify-content-between align-items-center @(isParentActive ? "" : "collapsed")"
                                       data-bs-toggle="collapse" href="#@collapseId">
                                    <span>
                                        <i class="@item.Icon @(isRtl ? "ms-2" : "me-2")"></i>
                                        @L[item.Title]
                                    </span>
                                    <i class="fas fa-chevron-down small transition-icon"></i>
                                </a>
                                <ul class="collapse @(isParentActive ? "show" : "") list-unstyled @(isRtl ? "pe-4" : "ps-4") mt-1" id="@collapseId">
                                    @foreach (var child in item.Children)
                                    {
                                        <li>
                                            <a class="nav-link @(IsActivePage(child.Url) ? "active fw-bold" : "") py-1" href="@child.Url">
                                                <i class="@child.Icon @(isRtl ? "ms-2" : "me-2") small"></i>
                                                @L[child.Title]
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link @(IsActivePage(item.Url) ? "active fw-bold" : "")" href="@item.Url">
                                    <i class="@item.Icon @(isRtl ? "ms-2" : "me-2")"></i>
                                    @L[item.Title]
                                </a>
                            </li>
                        }
                    }
                </ul>
            </div>
            <div class="sidebar-footer mt-auto p-3 border-top text-center text-muted small">
                © 2026 POS_LB
            </div>
        </aside>

        <main class="content flex-grow-1 bg-white">
            <div class="container-fluid mb-3">
                @* <breadcrumb></breadcrumb> *@
            </div>
            <div class="p-3 p-md-4">
                @RenderBody()
            </div>
        </main>
    </div>

    <div class="offcanvas offcanvas-start @(isRtl ? "offcanvas-end" : "offcanvas-start") d-lg-none" tabindex="-1" id="sidebarOffcanvas">
        <div class="offcanvas-header border-bottom">
            <h5 class="offcanvas-title fw-bold text-primary">POS_LB</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body">
            <ul class="nav nav-pills flex-column gap-1">
                @foreach (var item in filteredMenu)
                {
                    var mCollapseId = "m_menu_" + Math.Abs(item.Title.GetHashCode());
                    if (item.Children.Any())
                    {
                        <li class="nav-item">
                            <a class="nav-link d-flex justify-content-between" data-bs-toggle="collapse" href="#@mCollapseId">
                                <span><i class="@item.Icon me-2 ms-2"></i> @L[item.Title]</span>
                                <i class="fas fa-chevron-down small transition-icon"></i>
                            </a>
                            <ul class="collapse list-unstyled ps-3 pe-3 mt-1" id="@mCollapseId">
                                @foreach (var child in item.Children)
                                {
                                    <li><a class="nav-link @(IsActivePage(child.Url) ? "active" : "")" href="@child.Url">@L[child.Title]</a></li>
                                }
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link @(IsActivePage(item.Url) ? "active" : "")" href="@item.Url"><i class="@item.Icon me-2 ms-2"></i> @L[item.Title]</a></li>
                    }
                }
            </ul>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
            // دالة تغيير اللغة
            function setLanguage(culture) {
                document.cookie = ".AspNetCore.Culture=c=" + culture + "|uic=" + culture + "; path=/; expires=Fri, 31 Dec 9999 23:59:59 GMT";
                location.reload();
            }

            // منطق الوضع الليلي (Dark Mode) المتكامل
            (function() {
                const btn = document.getElementById("themeToggle");
                const root = document.documentElement;
                const icon = btn.querySelector("i");
            
                // قراءة المظهر المحفوظ أو استخدام الفاتح كافتراضي
                const savedTheme = localStorage.getItem("theme") || "light";
                root.setAttribute("data-theme", savedTheme);
            
                // ضبط الأيقونة الأولية
                if (savedTheme === "dark") {
                    icon.classList.replace("fa-moon", "fa-sun");
                }

                // التبديل عند النقر
                btn.addEventListener("click", () => {
                    const isDark = root.getAttribute("data-theme") === "dark";
                    const nextTheme = isDark ? "light" : "dark";
                
                    root.setAttribute("data-theme", nextTheme);
                    localStorage.setItem("theme", nextTheme);
                
                    icon.classList.toggle("fa-moon");
                    icon.classList.toggle("fa-sun");
                });
            })();
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>