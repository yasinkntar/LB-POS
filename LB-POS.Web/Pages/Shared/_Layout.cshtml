@using System.Security.Claims
@using Microsoft.Extensions.Localization
@using LB_POS.Core.Resources
@inject IStringLocalizer<SharedResources> L

@{
    bool IsActivePage(string pageName)
    {
        var currentPage = ViewContext.RouteData.Values["page"]?.ToString();
        return currentPage?.StartsWith(pageName, StringComparison.OrdinalIgnoreCase) == true;
    }
var displayName = User.FindFirstValue(ClaimTypes.GivenName) ??
                  User.FindFirstValue(ClaimTypes.Name) ??
                  User.Identity?.Name ??
                  "المستخدم";

    var culture = System.Globalization.CultureInfo.CurrentUICulture.Name;
    var isRtl = culture.StartsWith("ar");
}

<!DOCTYPE html>

<html lang="@culture" dir="@(isRtl ? "rtl" : "ltr")">

<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - POS_LB</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    @if (isRtl)
    {

        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" />
    }
    else
    {
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    }

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

</head>

<body class="app">

    <!-- ================= TOPBAR ================= -->

    <nav class="navbar topbar">

        <div class="container-fluid px-3">

            <button class="btn btn-light d-lg-none me-2"
                    type="button"
                    data-bs-toggle="offcanvas"
                    data-bs-target="#sidebarOffcanvas">

                <i class="fas fa-bars"></i>

            </button>

            <a class="navbar-brand fw-bold text-primary"
                   asp-page="/Index">

                <i class="fas fa-fingerprint me-1"></i>
                POS_LB

            </a>

            <div class="ms-auto d-flex align-items-center gap-2 gap-md-3">

                <!-- SEARCH -->

                <div class="d-none d-lg-block">

                    <div class="input-group input-group-sm">

                        <span class="input-group-text bg-light border-0">
                            <i class="fas fa-search text-muted"></i>
                        </span>

                        <input type="text"
                               class="form-control border-0 bg-light shadow-none"
                               placeholder="@L[SharedResourcesKeys.Sersch]"
                               style="min-width:200px">

                    </div>

                </div>

                <!-- NOTIFICATIONS -->

                <button class="btn btn-light position-relative">

                    <i class="fas fa-bell"></i>

                    <span class="position-absolute top-0 start-0 translate-middle badge rounded-pill bg-danger">

                        0

                    </span>

                </button>

                <!-- LANGUAGE -->

                <div class="dropdown">

                    <button class="btn btn-light dropdown-toggle" data-bs-toggle="dropdown">

                        <i class="fas fa-globe"></i>
                        <span class="lang-text ms-1">
                            @(isRtl ? "عربي" : "English")
                        </span>

                    </button>

                    <ul class="dropdown-menu dropdown-menu-end">

                        <li>
                            <a class="dropdown-item @(isRtl ? "active" : "")"
                                   href="#"
                                   onclick="setLanguage('ar-EG')">
                                العربية
                            </a>
                        </li>

                        <li>
                            <a class="dropdown-item @(!isRtl ? "active" : "")"
                                   href="#"
                                   onclick="setLanguage('en-US')">
                                English
                            </a>
                        </li>

                    </ul>

                </div>

                <!-- THEME -->

                <button class="btn btn-light" id="themeToggle">
                    <i class="fas fa-moon"></i>
                </button>

                <!-- USER -->
                @if (User.Identity?.IsAuthenticated == true)
                {

                    <div class="dropdown">

                        <button class="btn btn-light dropdown-toggle d-flex align-items-center gap-2"
                                data-bs-toggle="dropdown">

                            <i class="fas fa-user-circle text-primary"></i>

                            <span class="user-name">@displayName</span>

                        </button>

                        <ul class="dropdown-menu dropdown-menu-end shadow-sm">

                            <li class="dropdown-header text-center">

                                <i class="fas fa-user-circle fa-2x text-primary mb-1"></i>

                                <div>@displayName</div>

                            </li>

                            <li><hr class="dropdown-divider"></li>

                            <li>
                                <a class="dropdown-item" href="/Settings">
                                    @L["Settings"]
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item" href="/Profile">
                                    @L["Profile"]
                                </a>
                            </li>

                            <li><hr class="dropdown-divider"></li>

                            <li>
                                <form method="post" action="/logout">

                                    @Html.AntiForgeryToken()

                                    <button type="submit" class="dropdown-item text-danger">

                                        @L["Logout"]

                                    </button>

                                </form>

                            </li>

                        </ul>

                    </div>

                }
                else
                {

                    <a class="btn btn-primary btn-sm" href="/Login">

                        @L["Login"]

                    </a>

                }

            </div>

        </div>

    </nav>

    <!-- ================= BODY ================= -->

    <div class="app-body">

        <!-- SIDEBAR (Desktop) -->

        <aside class="sidebar d-none d-lg-block">

            <div class="mb-3 small text-muted">

                @L["Home"]

            </div>

            <ul class="nav nav-pills flex-column gap-1">

                <li>

                    <a class="nav-link @(IsActivePage("/Index") ? "active fw-bold" : "")"
                           asp-page="/Index">

                        <i class="fas fa-chart-line"></i>
                        @L["Dashboard"]

                    </a>

                </li>

            </ul>

            <div class="mt-4 mb-2 small text-muted">

                @L["UserManger"]

            </div>

            <ul class="nav nav-pills flex-column gap-1">

                <li>

                    <a class="nav-link @(IsActivePage("/Users") ? "active fw-bold" : "")"
                           asp-page="/UserManger/Index">

                        <i class="fas fa-code-branch"></i>
                        @L["Users"]

                    </a>

                </li>

            </ul>

            <hr />

            <div class="text-muted small">

                © 2026 POS_LB

            </div>

        </aside>

        <!-- CONTENT -->

        <main class="content">

            <div class="content-wrapper">

                @RenderBody()

            </div>

        </main>

    </div>

    <!-- MOBILE SIDEBAR -->

    <div class="offcanvas offcanvas-start d-lg-none"
         tabindex="-1"
         id="sidebarOffcanvas">

        <div class="offcanvas-header">

            <h5 class="offcanvas-title">POS_LB</h5>

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="offcanvas"></button>

        </div>

        <div class="offcanvas-body">

            <a class="nav-link @(IsActivePage("/Index") ? "active" : "")"
                   asp-page="/Index">

                <i class="fas fa-chart-line me-1"></i>
                @L["Dashboard"]

            </a>

            <a class="nav-link @(IsActivePage("/Branches") ? "active" : "")"
                   asp-page="/Branches/Index">

                <i class="fas fa-code-branch me-1"></i>
                @L["Branches"]

            </a>

        </div>

    </div>

    <!-- ================= Scripts ================= -->

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>

            (function(){

            const btn=document.getElementById("themeToggle");
            if(!btn) return;

            const root=document.documentElement;
            const saved=localStorage.getItem("theme");

            if(saved) root.setAttribute("data-theme",saved);

            btn.addEventListener("click",()=>{

            const icon=btn.querySelector("i");

            const current=root.getAttribute("data-theme");
            const next=current==="dark"?"light":"dark";

            root.setAttribute("data-theme",next);
            localStorage.setItem("theme",next);

            icon.classList.toggle("fa-moon");
            icon.classList.toggle("fa-sun");

            });

            })();

            function setLanguage(culture){

            document.cookie=".AspNetCore.Culture=c="+culture+"|uic="+culture+"; path=/; expires=Fri, 31 Dec 9999 23:59:59 GMT";

            location.reload();

            }

            document.querySelectorAll('#sidebarOffcanvas .nav-link').forEach(link=>{

            link.addEventListener('click',()=>{

            const el=document.getElementById('sidebarOffcanvas');
            const off=bootstrap.Offcanvas.getInstance(el);

            if(off) off.hide();

            });

            });

    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
