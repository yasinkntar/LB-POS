@page "/Users"
@model LB_POS.Web.Pages.UserManger.IndexModel
@{
    ViewData["Title"] = "Users";
}

<!-- Page-specific styles (overrides/customizations if needed) -->
<style>
    /* Use theme variables */
    .search-input-group {
        max-width: 350px;
    }

    .badge-total {
        background-color: var(--primary-soft);
        color: var(--primary);
        font-weight: 500;
        padding: 0.5rem 1rem;
        border-radius: 2rem;
        font-size: 0.875rem;
    }

    /* Table action buttons – keep subtle */
    .btn-action {
        padding: 0.25rem 0.5rem;
        font-size: 0.875rem;
        line-height: 1;
        border-radius: 0.375rem;
        border: none;
        background: transparent;
        transition: all 0.2s;
    }
    .btn-action i {
        font-size: 1rem;
    }
    .btn-action:hover {
        background-color: var(--primary-soft);
        color: var(--primary);
    }
    .btn-action.text-danger:hover {
        background-color: rgba(220,38,38,0.1);
        color: #dc2626;
    }

    /* Search input group – match theme */
    .input-group-text {
        background: transparent;
        border: 1px solid var(--border);
        border-right: none;
    }
    .form-control {
        background: transparent;
        border: 1px solid var(--border);
        color: var(--text);
    }
    .form-control:focus {
        background: transparent;
        border-color: var(--primary);
        box-shadow: 0 0 0 0.2rem var(--primary-soft);
    }
    .btn-outline-secondary {
        border-color: var(--border);
        color: var(--text-muted);
    }
    .btn-outline-secondary:hover {
        background-color: var(--primary-soft);
        border-color: var(--primary);
        color: var(--primary);
    }

    /* Pagination */
    .page-item .page-link {
        background-color: transparent;
        border: 1px solid var(--border);
        color: var(--text);
    }
    .page-item.active .page-link {
        background-color: var(--primary);
        border-color: var(--primary);
        color: white;
    }
    .page-item.disabled .page-link {
        background-color: transparent;
        border-color: var(--border);
        color: var(--text-muted);
    }

    /* Modal */
    .modal-content {
        background-color: var(--card-bg);
        border: none;
        border-radius: var(--radius);
        box-shadow: var(--shadow-md);
    }
    .modal-header, .modal-footer {
        border-color: var(--border);
    }
    .btn-close {
        filter: invert(1);
    }
    [data-theme="dark"] .btn-close {
        filter: invert(0);
    }
</style>

<!-- Main content – placed inside the layout's .content-wrapper -->
<div class="content-wrapper">
    <!-- Header -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-0 fw-semibold">Users Management</h4>
            <p class="text-muted mt-1 mb-0">View and manage all registered users</p>
        </div>
        <div class="mt-2 mt-sm-0">
      <a asp-page="/UserManger/CreateUser" class="btn btn-primary rounded-pill px-4">
    <i class="bi bi-person-plus me-1"></i> Add User
</a>
        </div>
    </div>

    <!-- Search & Stats -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 pb-2 border-bottom">
        <div class="mb-2 mb-sm-0">
            <span class="badge-total">
                <i class="bi bi-people me-1"></i> Total: @Model.Users.TotalCount users
            </span>
        </div>
        <div class="search-input-group">
            <div class="input-group">
                <span class="input-group-text bg-transparent border-end-0">
                    <i class="bi bi-search text-muted"></i>
                </span>
                <input type="text" id="searchInput" class="form-control border-start-0 ps-0" placeholder="Search by name, email or phone..." onkeyup="filterTable()">
                <button class="btn btn-outline-secondary" type="button" onclick="clearSearch()">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Users Table -->
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                     <th>ID</th>
                    <th>Full Name</th>
                    <th>UserName</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody id="usersTableBody">
                @foreach (var user in Model.Users.Data)
                {
                    <tr>
                        <td>@user.ID</td>
                        <td class="fw-medium">@user.FullName</td>
                        <td class="fw-medium">@user.UserName</td>                        
                        <td>@user.Email</td>
                        <td>@user.PhoneNumber</td>
                        <td class="text-end">
                            <button class="btn-action me-2" onclick="editUser()" title="Edit">
                                <i class="bi bi-pencil-square"></i>
                            </button>
                            <button class="btn-action text-danger" onclick="deleteUser()" title="Delete">
                                <i class="bi bi-trash3"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <!-- No results message -->
        <div id="noResultsMessage" class="text-center py-5 d-none">
            <i class="bi bi-inbox fs-1 text-muted"></i>
            <p class="text-muted mt-2 mb-0">No users found matching your search.</p>
        </div>
    </div>

    <!-- Pagination -->
    @{
        int totalPages = (int)Math.Ceiling((double)Model.Users.TotalCount / Model.PageSize);
        int currentPage = Model.PageNumber;
        int maxDisplay = 5;
        int halfDisplay = maxDisplay / 2;
        int startPage = currentPage - halfDisplay;
        int endPage = currentPage + halfDisplay;

        if (startPage < 1)
        {
            startPage = 1;
            endPage = Math.Min(totalPages, maxDisplay);
        }
        if (endPage > totalPages)
        {
            endPage = totalPages;
            startPage = Math.Max(1, totalPages - maxDisplay + 1);
        }
    }

    @if (totalPages > 1)
    {
        <nav aria-label="Page navigation" class="mt-4">
            <ul class="pagination justify-content-center mb-0">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link" href="?PageNumber=@(currentPage - 1)" aria-label="Previous">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>
                @if (startPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="?PageNumber=1">1</a>
                    </li>
                    @if (startPage > 2)
                    {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                }
                @for (int i = startPage; i <= endPage; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" href="?PageNumber=@i">@i</a>
                    </li>
                }
                @if (endPage < totalPages)
                {
                    @if (endPage < totalPages - 1)
                    {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                    <li class="page-item">
                        <a class="page-link" href="?PageNumber=@totalPages">@totalPages</a>
                    </li>
                }
                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link" href="?PageNumber=@(currentPage + 1)" aria-label="Next">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>

<!-- Add User Modal -->
<div class="modal fade" id="addUserModal" tabindex="-1" aria-labelledby="addUserModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addUserModalLabel">Add New User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="addUserForm">
                    <div class="mb-3">
                        <label for="fullName" class="form-label">Full Name</label>
                        <input type="text" class="form-control" id="fullName" required>
                    </div>
                    <div class="mb-3">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" class="form-control" id="email" required>
                    </div>
                    <div class="mb-3">
                        <label for="phone" class="form-label">Phone</label>
                        <input type="tel" class="form-control" id="phone">
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="submitAddUser()">Save User</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function filterTable() {
            const input = document.getElementById("searchInput");
            const filter = input.value.toLowerCase().trim();
            const tableBody = document.getElementById("usersTableBody");
            const rows = tableBody.getElementsByTagName("tr");
            let visibleCount = 0;

            for (let i = 0; i < rows.length; i++) {
                const row = rows[i];
                const text = row.innerText.toLowerCase();
                if (text.includes(filter)) {
                    row.style.display = "";
                    visibleCount++;
                } else {
                    row.style.display = "none";
                }
            }

            const noResults = document.getElementById("noResultsMessage");
            if (visibleCount === 0) {
                noResults.classList.remove("d-none");
            } else {
                noResults.classList.add("d-none");
            }
        }

        function clearSearch() {
            const searchInput = document.getElementById("searchInput");
            searchInput.value = "";
            filterTable();
        }

        // Replace with actual logic
        function editUser(userId) {
            alert("Edit user: " + userId);
        }

        function deleteUser(userId) {
            if (confirm("Are you sure you want to delete this user?")) {
                alert("Delete user: " + userId);
            }
        }

        function submitAddUser() {
            // Gather form data and send to server
            alert("User added (demo)");
            $('#addUserModal').modal('hide');
        }
    </script>
}