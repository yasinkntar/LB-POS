@page "/Users"
@using LB_POS.Core.Resources
@using Microsoft.Extensions.Localization
@using LB_POS.Core.Behavior;
@model LB_POS.Web.Pages.UserManger.IndexModel

@{
    ViewData["Title"] = L[SharedResourcesKeys.UsersManagement];
    var isRtl = System.Globalization.CultureInfo.CurrentUICulture.TextInfo.IsRightToLeft;
}
@inject IStringLocalizer<SharedResources> L

@* <div class="content-wrapper"> *@
    <div class="row align-items-center mb-4">
        <div class="col-md-6">
            <h4 class="mb-1 fw-bold text-primary">
                <i class="fas fa-users-cog @(isRtl ? "ms-2" : "me-2")"></i>@L[SharedResourcesKeys.UsersManagement]
            </h4>
        </div>
        <div class="col-md-6 d-flex justify-content-md-end gap-2 mt-3 mt-md-0">
            <a asp-page="CreateUser" asp-permission="CreateUser" class="btn btn-primary px-4 shadow-sm d-flex align-items-center">
                <i class="fas fa-plus-circle @(isRtl ? "ms-2" : "me-2")"></i> @L[SharedResourcesKeys.AddUser]
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4 rounded-4 overflow-hidden">
        <div class="card-body p-3 bg-card-custom">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <div class="custom-input-group">
                        <i class="fas fa-search icon"></i>
                        <input name="SearchTerm"
                            class="form-control custom-control" 
                           value="@Model.SearchTerm"
                            placeholder="@L["البحث بالاسم أو البريد..."]">
                    </div>
                </div>
                <div class="col-md-3">
          
                </div>
                <div class="col-md-5 d-flex gap-2 justify-content-md-end">
                    <button type="submit" class="btn btn-primary px-4">@L["تصفية"]</button>
                    <a asp-page="Index" class="btn btn-light border px-3">@L["إعادة ضبط"]</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="table-responsive">
            <table class="table custom-table-style align-middle mb-0">
                <thead>
                    <tr>
                        <th class="@(isRtl ? "ps-4" : "pe-4")">@L[SharedResourcesKeys.FullName]</th>
                        <th>@L[SharedResourcesKeys.UserName]</th>
                        <th>@L[SharedResourcesKeys.Email]</th>
                        <th class="text-center">@L[SharedResourcesKeys.Actions]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Users?.Data != null && Model.Users.Data.Any())
                    {
                        @foreach (var user in Model.Users.Data)
                        {
                            <tr>
                            <td class="@(isRtl ? "ps-4" : "pe-4")">
                                <div class="d-flex align-items-center">
                                    <div class="user-avatar-styled @(isRtl ? "ms-3" : "me-3")">
                                        @if (!string.IsNullOrEmpty(user.FullName))
                                        {
                                            <span>@user.FullName[0].ToString().ToUpper()</span>
                                        }
                                        else
                                        {
                                            <i class="fas fa-user-circle"></i>
                                        }
                                    </div>
        
                                    <div class="user-info d-flex flex-column justify-content-center">
                                        <div class="fw-bold mb-0 text-dark-emphasis lh-1">
                                            @(user.FullName ?? L[SharedResourcesKeys.NoName])
                                        </div>
                                        <div class="text-muted mt-1" style="font-size: 1rem; letter-spacing: 0.5px;">
                                            <span class="badge bg-light text-muted border-0 fw-normal p-0">
                                                ID: <span class="text-primary-emphasis fw-semibold">#@user.ID</span>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </td>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span class="text-primary-emphasis fw-medium">@@@(user.UserName ?? "---")</span>
                                        <small class="text-muted small">@user.PhoneNumber</small>
                                    </div>
                                </td>
                     
                                <td class="text-muted small">@(user.Email ?? L[SharedResourcesKeys.NoEmail])</td>
                                <td class="text-center">
                                    <div class="dropdown">
                                        <button class="btn btn-light-soft btn-sm px-2" data-bs-toggle="dropdown">
                                            <i class="fas fa-ellipsis-v"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                        <li><a class="dropdown-item py-2" asp-permission="EditUser" asp-page="EditUser" asp-route-id="@user.ID"><i class="fas fa-edit me-2 ms-2 text-primary"></i>@L[SharedResourcesKeys.Edit]</a></li>
                                        <li><a class="dropdown-item py-2" asp-permission="EditRoleUser" asp-page="/Roles/ManageUserRoles" asp-route-userId="@user.ID"><i class="fas fa-user-shield me-2 ms-2 text-indigo"></i>@L[SharedResourcesKeys.RoleUser]</a></li>
                                        <li><a class="dropdown-item py-2" asp-permission="EditPermissionUser" asp-page="/Roles/ManageUserClaims" asp-route-userId="@user.ID"><i class="fas fa-fingerprint me-2 ms-2 text-warning"></i>@L[SharedResourcesKeys.UserPermissions]</a></li>
                                            <li><hr class="dropdown-divider"></li>
                                            <li>
                                            <form method="post" asp-page-handler="Delete" asp-permission="DeleteUser" asp-route-id="@user.ID" class="delete-form">
                                                    <button type="button" class="dropdown-item py-2 text-danger btn-delete-confirm">
                                                        <i class="fas fa-trash me-2 ms-2"></i> @L[SharedResourcesKeys.Delete]
                                                    </button>
                                                </form>
                                            </li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="d-flex flex-column flex-sm-row align-items-center justify-content-between mt-4 gap-3 bg-light-soft p-3 rounded-4">
        <div class="text-muted small">
            @L["عرض"] <span class="fw-bold text-dark">@(((Model.PageNumber - 1) * Model.PageSize) + 1)</span>
            @L["إلى"] <span class="fw-bold text-dark">@Math.Min(Model.PageNumber * Model.PageSize, Model.Users.TotalCount)</span>
            @L["من أصل"] <span class="fw-bold text-dark">@Model.Users.TotalCount</span> @L["مستخدم"]
        </div>
        <nav>
            <ul class="pagination pagination-rounded mb-0">
                <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
                    <a class="page-link border-0" asp-route-PageNumber="@(Model.PageNumber - 1)"><i class="fas @(isRtl ? "fa-chevron-right" : "fa-chevron-left")"></i></a>
                </li>
                @for (int i = 1; i <= Model.Users.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                        <a class="page-link border-0 mx-1" asp-route-PageNumber="@i">@i</a>
                    </li>
                }
                <li class="page-item @(Model.PageNumber == Model.Users.TotalPages ? "disabled" : "")">
                    <a class="page-link border-0" asp-route-PageNumber="@(Model.PageNumber + 1)"><i class="fas @(isRtl ? "fa-chevron-left" : "fa-chevron-right")"></i></a>
                </li>
            </ul>
        </nav>
    </div>
@* </div> *@