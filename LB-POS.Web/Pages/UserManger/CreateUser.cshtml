@page
@using LB_POS.Core.Resources
@using Microsoft.Extensions.Localization
@model LB_POS.Web.Pages.UserManger.CreateUserModel

@{
    ViewData["Title"] = L[SharedResourcesKeys.CreateUser];
    var isRtl = System.Globalization.CultureInfo.CurrentUICulture.TextInfo.IsRightToLeft;
}

@inject IStringLocalizer<SharedResources> L

@* --- الهيدر العلوي ومسار التنقل --- *@
<div class="row align-items-center mb-4">
    <div class="col-md-6">
        <h4 class="mb-1 fw-bold text-primary">
            <i class="fas fa-user-plus @(isRtl ? "ms-2" : "me-2")"></i>@L[SharedResourcesKeys.CreateUser]
        </h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-page="Index" class="text-decoration-none">@L["إدارة المستخدمين"]</a></li>
                <li class="breadcrumb-item active" aria-current="page">@L[SharedResourcesKeys.CreateUser]</li>
            </ol>
        </nav>
    </div>
    <div class="col-md-6 d-flex justify-content-md-end mt-3 mt-md-0">
        <a asp-page="Index" class="btn btn-outline-secondary px-4 shadow-sm d-flex align-items-center rounded-pill">
            <i class="fas @(isRtl ? "fa-arrow-right ms-2" : "fa-arrow-left me-2")"></i> @L[SharedResourcesKeys.BackToList]
        </a>
    </div>
</div>

<form method="post" class="needs-validation" novalidate>
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 shadow-sm border-0 mb-4"></div>

    <div class="row g-4">
        @* --- بطاقة البيانات الشخصية --- *@
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-light py-3 border-bottom">
                    <h6 class="mb-0 text-primary fw-bold"><i class="fas fa-id-card mx-2"></i>@L["البيانات الشخصية"]</h6>
                </div>
                <div class="card-body p-4 bg-white">
                    <div class="row g-4">
                        <div class="col-12">
                            <label asp-for="AddUser.FullName" class="form-label fw-bold small text-muted">@L[SharedResourcesKeys.FullName] <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="fas fa-user text-muted"></i></span>
                                <input asp-for="AddUser.FullName" class="form-control bg-light border-0" placeholder="@L[SharedResourcesKeys.EnterFullName]" required>
                                </div>
                                <span asp-validation-for="AddUser.FullName" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="AddUser.PhoneNumber" class="form-label fw-bold small text-muted">@L[SharedResourcesKeys.PhoneNumber] <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="fas fa-phone text-muted"></i></span>
                                    <input asp-for="AddUser.PhoneNumber" class="form-control bg-light border-0 text-start" dir="ltr" placeholder="@L[SharedResourcesKeys.EnterPhone]" required>
                                    </div>
                                    <span asp-validation-for="AddUser.PhoneNumber" class="text-danger small mt-1 d-block"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="AddUser.Email" class="form-label fw-bold small text-muted">@L[SharedResourcesKeys.Email] <span class="text-danger">*</span></label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-0"><i class="fas fa-envelope text-muted"></i></span>
                                        <input asp-for="AddUser.Email" type="email" class="form-control bg-light border-0 text-start" dir="ltr" placeholder="@L[SharedResourcesKeys.EnterEmail]" required>
                                        </div>
                                        <span asp-validation-for="AddUser.Email" class="text-danger small mt-1 d-block"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    @* --- بطاقة بيانات الدخول والأمان --- *@
                    <div class="col-lg-6">
                        <div class="card border-0 shadow-sm rounded-4 h-100">
                            <div class="card-header bg-light py-3 border-bottom">
                                <h6 class="mb-0 text-primary fw-bold"><i class="fas fa-user-shield mx-2"></i>@L["بيانات الدخول"]</h6>
                            </div>
                            <div class="card-body p-4 bg-white">
                                <div class="row g-4">
                                    <div class="col-12">
                                        <label asp-for="AddUser.UserName" class="form-label fw-bold small text-muted">@L[SharedResourcesKeys.UserName] <span class="text-danger">*</span></label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-0"><i class="fas fa-user-tag text-muted"></i></span>
                                            <input asp-for="AddUser.UserName" class="form-control bg-light border-0 text-start" dir="ltr" placeholder="@L[SharedResourcesKeys.EnterUserName]" required>
                                            </div>
                                            <span asp-validation-for="AddUser.UserName" class="text-danger small mt-1 d-block"></span>
                                        </div>

                                        <div class="col-md-6">
                                            <label asp-for="AddUser.Password" class="form-label fw-bold small text-muted">@L[SharedResourcesKeys.Password] <span class="text-danger">*</span></label>
                                            <div class="input-group">
                                                <span class="input-group-text bg-light border-0"><i class="fas fa-lock text-muted"></i></span>
                                                <input asp-for="AddUser.Password" type="password" id="password" class="form-control bg-light border-0 text-start" dir="ltr" placeholder="••••••••" required>
                                                    <button type="button" class="input-group-text bg-light border-0 text-muted" onclick="togglePass('password', this)">
                                                        <i class="fas fa-eye"></i>
                                                    </button>
                                                </div>
                                                <span asp-validation-for="AddUser.Password" class="text-danger small mt-1 d-block"></span>
                                            </div>

                                            <div class="col-md-6">
                                                <label asp-for="AddUser.ConfirmPassword" class="form-label fw-bold small text-muted">@L[SharedResourcesKeys.ConfirmPassword] <span class="text-danger">*</span></label>
                                                <div class="input-group">
                                                    <span class="input-group-text bg-light border-0"><i class="fas fa-shield-alt text-muted"></i></span>
                                                    <input asp-for="AddUser.ConfirmPassword" type="password" id="confirmPassword" class="form-control bg-light border-0 text-start" dir="ltr" placeholder="••••••••" required>
                                                        <button type="button" class="input-group-text bg-light border-0 text-muted" onclick="togglePass('confirmPassword', this)">
                                                            <i class="fas fa-eye"></i>
                                                        </button>
                                                    </div>
                                                    <span asp-validation-for="AddUser.ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                @* --- قسم الأزرار --- *@
                                <div class="col-12 mt-4 mb-5">
                                    <div class="card border-0 shadow-sm rounded-4 p-3 bg-white">
                                        <div class="d-flex justify-content-end gap-3">
                                            <button type="reset" class="btn btn-light border px-4 rounded-pill">
                                                @L[SharedResourcesKeys.Reset]
                                            </button>
                                            <button type="submit" class="btn btn-primary px-5 shadow-sm rounded-pill">
                                                <i class="fas fa-save mx-2"></i> @L[SharedResourcesKeys.SaveUser]
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </form>

                        @section Scripts {
                            <partial name="_ValidationScriptsPartial" />
    
                            <script>
                                // دالة إظهار وإخفاء كلمة المرور الأنيقة
                                function togglePass(inputId, btn) {
                                    const input = document.getElementById(inputId);
                                    const icon = btn.querySelector('i');
            
                                    if (input.type === "password") {
                                        input.type = "text";
                                        icon.classList.replace('fa-eye', 'fa-eye-slash');
                                        btn.classList.add('text-primary'); // إضافة لون عند الإظهار
                                    } else {
                                        input.type = "password";
                                        icon.classList.replace('fa-eye-slash', 'fa-eye');
                                        btn.classList.remove('text-primary');
                                    }
                                }

                                // تفعيل التحقق (Validation) الخاص بـ Bootstrap
                                (function () {
                                    'use strict'
                                    var forms = document.querySelectorAll('.needs-validation')
                                    Array.prototype.slice.call(forms)
                                        .forEach(function (form) {
                                            form.addEventListener('submit', function (event) {
                                                if (!form.checkValidity()) {
                                                    event.preventDefault()
                                                    event.stopPropagation()
                                                }
                                                form.classList.add('was-validated')
                                            }, false)
                                        })
                                })()
                            </script>
                        }