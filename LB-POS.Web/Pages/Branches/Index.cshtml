@page "/Branches"
@using LB_POS.Core.Resources
@using Microsoft.Extensions.Localization
@using LB_POS.Core.Behavior;
@model LB_POS.Web.Pages.Branches.IndexModel

@{
    ViewData["Title"] = L[SharedResourcesKeys.BranchesManagement]; // تأكد من إضافة المفتاح في ملف المصادر
    var isRtl = System.Globalization.CultureInfo.CurrentUICulture.TextInfo.IsRightToLeft;
}
@inject IStringLocalizer<SharedResources> L

<div class="row align-items-center mb-4">
    <div class="col-md-6">
        <h4 class="mb-1 fw-bold text-primary">
            <i class="fas fa-map-marked-alt @(isRtl ? "ms-2" : "me-2")"></i>@L[SharedResourcesKeys.BranchesManagement]
        </h4>
    </div>
    <div class="col-md-6 d-flex justify-content-md-end gap-2 mt-3 mt-md-0">
        <a asp-page="CreateBranch" asp-permission="CreateBranch" class="btn btn-primary px-4 shadow-sm d-flex align-items-center">
            <i class="fas fa-plus-circle @(isRtl ? "ms-2" : "me-2")"></i> @L[SharedResourcesKeys.AddBranch]
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4 rounded-4 overflow-hidden">
    <div class="card-body p-3 bg-card-custom">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <div class="custom-input-group">
                    <i class="fas fa-search icon"></i>
                    <input name="SearchTerm"
                           class="form-control custom-control" 
                           value="@Model.SearchTerm"
                           placeholder=@L[SharedResourcesKeys.Placeholder]>
                </div>
            </div>
            <div class="col-md-3">
                </div>
            <div class="col-md-5 d-flex gap-2 justify-content-md-end">
                <button type="submit" class="btn btn-primary px-4">@L[SharedResourcesKeys.Filter]</button>
                <a asp-page="Index" class="btn btn-light border px-3">@L[SharedResourcesKeys.Reset]</a>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="table-responsive">
        <table class="table custom-table-style align-middle mb-0">
            <thead>
                <tr>
                    <th class="@(isRtl ? "ps-4" : "pe-4")">@L[SharedResourcesKeys.Branch]</th>
                    <th>
                        @L[SharedResourcesKeys.ActivityCode]</th>
                    <th>@L[SharedResourcesKeys.Address]</th>
                    <th class="text-center">@L[SharedResourcesKeys.Actions]</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Branch?.Data != null && Model.Branch.Data.Any())
                {
                    @foreach (var branch in Model.Branch.Data)
                    {
                        <tr>
                            <td class="@(isRtl ? "ps-4" : "pe-4")">
                                <div class="d-flex align-items-center">
                                    <div class="user-avatar-styled @(isRtl ? "ms-3" : "me-3") bg-primary-soft text-primary">
                                        @if (!string.IsNullOrEmpty(branch.Name))
                                        {
                                            <span>@branch.Name[0].ToString().ToUpper()</span>
                                        }
                                        else
                                        {
                                            <i class="fas fa-store"></i>
                                        }
                                    </div>
                                    <div class="user-info d-flex flex-column justify-content-center">
                                        <div class="fw-bold mb-0 text-dark-emphasis lh-1">
                                            @(branch.Name ?? L[SharedResourcesKeys.NoName])
                                        </div>
                                        <div class="text-muted mt-1" style="font-size: 0.85rem;">
                                            <span class="badge bg-light text-muted border-0 fw-normal p-0">
                                                Code: <span class="text-primary-emphasis fw-semibold">#@branch.Code</span>
                                            </span>
                                            <span class="mx-1">|</span>
                                            <span class="small">@branch.Name</span>
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-info-soft text-info fw-medium">@branch.ActivityCode</span>
                            </td>
                            <td>
                                <div class="d-flex flex-column">
                                    <span class="text-dark small"><i class="fas fa-map-marker-alt text-danger me-1 ms-1"></i> @branch.FullAddressc</span>
                                    @* <small class="text-muted" style="font-size: 0.75rem;">@branch.Address.Street, @branch.Address.BuildingNumber</small> *@
                                </div>
                            </td>
                            <td class="text-center">
                                <div class="dropdown">
                                    <button class="btn btn-light-soft btn-sm px-2" data-bs-toggle="dropdown">
                                        <i class="fas fa-ellipsis-v"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                        <li><a class="dropdown-item py-2" asp-permission="EditBranch" asp-page="EditBranch" asp-route-id="@branch.Code"><i class="fas fa-edit me-2 ms-2 text-primary"></i>@L[SharedResourcesKeys.Edit]</a></li>
                                        <li><a class="dropdown-item py-2" asp-page="BranchDetails" asp-route-id="@branch.Code"><i class="fas fa-info-circle me-2 ms-2 text-info"></i>@L["التفاصيل"]</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <form method="post" asp-page-handler="Delete" asp-route-id="@branch.Id" id="delete-form-@branch.Id">
                                                <button type="button" class="dropdown-item py-2 text-danger btn-delete-confirm" onclick="confirmDelete('@branch.Id')">
                                                    <i class="fas fa-trash me-2 ms-2"></i> @L[SharedResourcesKeys.Delete]
                                                </button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted">
                            <i class="fas fa-store-slash fa-3x mb-3 d-block"></i>
                            @L[SharedResourcesKeys.NoBranches]
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* الجزء الخاص بالتنقيم (Pagination) بنفس المنطق الخاص بك *@
<div class="d-flex flex-column flex-sm-row align-items-center justify-content-between mt-4 gap-3 bg-light-soft p-3 rounded-4">
    <div class="text-muted small">
        @L[SharedResourcesKeys.Showing] <span class="fw-bold text-dark">@(((Model.PageNumber - 1) * Model.PageSize) + 1)</span>
        @L[SharedResourcesKeys.To] <span class="fw-bold text-dark">@Math.Min(Model.PageNumber * Model.PageSize, Model.Branch.TotalCount)</span>
        @L[SharedResourcesKeys.ShowingRange] <span class="fw-bold text-dark">@Model.Branch.TotalCount</span> @L[SharedResourcesKeys.Branch]
    </div>
    <nav>
        <ul class="pagination pagination-rounded mb-0">
            <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
                <a class="page-link border-0" asp-route-PageNumber="@(Model.PageNumber - 1)" asp-route-SearchTerm="@Model.SearchTerm"><i class="fas @(isRtl ? "fa-chevron-right" : "fa-chevron-left")"></i></a>
            </li>
            @for (int i = 1; i <= Model.Branch.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link border-0 mx-1" asp-route-PageNumber="@i" asp-route-SearchTerm="@Model.SearchTerm">@i</a>
                </li>
            }
            <li class="page-item @(Model.PageNumber == Model.Branch.TotalPages ? "disabled" : "")">
                <a class="page-link border-0" asp-route-PageNumber="@(Model.PageNumber + 1)" asp-route-SearchTerm="@Model.SearchTerm"><i class="fas @(isRtl ? "fa-chevron-left" : "fa-chevron-right")"></i></a>
            </li>
        </ul>
    </nav>
</div>
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmDelete(id) {
        Swal.fire({
        title: '@L["هل أنت متأكد؟"]',
        text: 'AAAAAAAAAAAAA',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        cancelButtonColor: '#3085d6',
        confirmButtonText: '@L["نعم، احذف!"]',
        cancelButtonText: '@L["إلغاء"]'
        }).then((result) => {
        if (result.isConfirmed) {
        // إرسال الفورم برمجياً
        document.getElementById('delete-form-' + id).submit();
        }
        })
        }
    </script>
}