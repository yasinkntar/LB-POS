@page "/Sections"
@using LB_POS.Core.Resources
@using Microsoft.Extensions.Localization
@using LB_POS.Core.Behavior;
@model LB_POS.Web.Pages.Sections.IndexModel

@{
    ViewData["Title"] = L["إدارة الأقسام"];
    var isRtl = System.Globalization.CultureInfo.CurrentUICulture.TextInfo.IsRightToLeft;
}

@inject IStringLocalizer<SharedResources> L

@* --- الهيدر --- *@
<div class="row align-items-center mb-4">
    <div class="col-md-6">
        <h4 class="mb-1 fw-bold text-primary">
            <i class="fas fa-th-large @(isRtl ? "ms-2" : "me-2")"></i>@L["إدارة الأقسام"]
        </h4>
    </div>
    <div class="col-md-6 d-flex justify-content-md-end gap-2 mt-3 mt-md-0">
        <a asp-page="CreateSection" asp-permission="CreateSection" class="btn btn-primary px-4 shadow-sm d-flex align-items-center">
            <i class="fas fa-plus-circle @(isRtl ? "ms-2" : "me-2")"></i> @L["إضافة قسم جديد"]
        </a>
    </div>
</div>

@* --- قسم البحث --- *@
<div class="card border-0 shadow-sm mb-4 rounded-4 overflow-hidden">
    <div class="card-body p-3 bg-card-custom">
        <form method="get" id="filterForm" class="row g-3">
            @* نحتفظ بقيمة حجم الصفحة عند إرسال فورم البحث *@
            <input type="hidden" name="PageSize" value="@Model.PageSize" />
            
            <div class="col-md-4">
                <div class="custom-input-group">
                    <i class="fas fa-search icon"></i>
                    <input name="SearchTerm"
                           class="form-control custom-control" 
                           value="@Model.SearchTerm"
                           placeholder=@L[SharedResourcesKeys.Placeholder]>
                </div>
            </div>
            <div class="col-md-8 d-flex gap-2 justify-content-md-end">
                <button type="submit" class="btn btn-primary px-4">@L[SharedResourcesKeys.Filter]</button>
                <a asp-page="Index" class="btn btn-light border px-3">@L[SharedResourcesKeys.Reset]</a>
            </div>
        </form>
    </div>
</div>

@* --- الجدول --- *@
<div class="card border-0 shadow-sm rounded-4">
    <div class="table-responsive">
        <table class="table custom-table-style align-middle mb-0">
            <thead>
                <tr>
                    <th class="@(isRtl ? "ps-4" : "pe-4")">@L["القسم"]</th>
                    <th>@L["الفرع"]</th>
                    <th>@L["ترتيب العرض"]</th>
                    <th class="text-center">@L[SharedResourcesKeys.Actions]</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Section?.Data != null && Model.Section.Data.Any())
                {
                    @foreach (var section in Model.Section.Data)
                    {
                        <tr>
                            <td class="@(isRtl ? "ps-4" : "pe-4")">
                                <div class="d-flex align-items-center">
                                    <div class="user-avatar-styled @(isRtl ? "ms-3" : "me-3") bg-info-soft text-info">
                                        <span>@section.Name[0].ToString().ToUpper()</span>
                                    </div>
                                    <div class="user-info">
                                        <div class="fw-bold mb-0 text-dark-emphasis">@section.Name</div>
                                        <div class="text-muted small">@section.NameEn</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="text-secondary"><i class="fas fa-store-alt me-1 ms-1 small"></i> @section.BranchName</span>
                            </td>
                            <td>
                                <span class="badge bg-light text-primary border px-2">@section.DisplayOrder</span>
                            </td>
                            <td class="text-center">
                                <div class="dropdown">
                                    <button class="btn btn-light-soft btn-sm px-2" data-bs-toggle="dropdown">
                                        <i class="fas fa-ellipsis-v"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                        <li><a class="dropdown-item py-2" asp-permission="EditSection" asp-page="EditSection" asp-route-id="@section.Id"><i class="fas fa-edit me-2 ms-2 text-primary"></i>@L[SharedResourcesKeys.Edit]</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <form method="post" asp-page-handler="Delete" asp-route-id="@section.Id" id="delete-form-@section.Id">
                                                <button type="button" class="dropdown-item py-2 text-danger" onclick="confirmDelete('@section.Id')">
                                                    <i class="fas fa-trash me-2 ms-2"></i> @L[SharedResourcesKeys.Delete]
                                                </button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted">@L["لا توجد بيانات"]</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* --- التنقيم (Pagination) المعدل --- *@
<div class="d-flex flex-column flex-sm-row align-items-center justify-content-between mt-4 gap-3 bg-light-soft p-3 rounded-4">
    <div class="d-flex align-items-center gap-3">
        @* كمبو تحديد عدد الأسطر *@
        <div class="d-flex align-items-center bg-white border rounded-3 px-2">
            <span class="text-muted small me-2 ms-2">@L["عرض"]</span>
            <select class="form-select form-select-sm border-0 shadow-none" 
                    style="width: auto; cursor: pointer;"
                    onchange="location.href='?PageNumber=1&SearchTerm=@Model.SearchTerm&PageSize=' + this.value">
                <option value="10" selected="@(Model.PageSize == 10)">10</option>
                <option value="25" selected="@(Model.PageSize == 25)">25</option>
                <option value="50" selected="@(Model.PageSize == 50)">50</option>
                <option value="100" selected="@(Model.PageSize == 100)">100</option>
            </select>
        </div>

        <div class="text-muted small">
            @L[SharedResourcesKeys.Showing] <span class="fw-bold text-dark">@(((Model.PageNumber - 1) * Model.PageSize) + 1)</span>
            @L[SharedResourcesKeys.To] <span class="fw-bold text-dark">@Math.Min(Model.PageNumber * Model.PageSize, Model.Section.TotalCount)</span>
            @L[SharedResourcesKeys.ShowingRange] <span class="fw-bold text-dark">@Model.Section.TotalCount</span> @L["قسم"]
        </div>
    </div>

    <nav>
        <ul class="pagination pagination-rounded mb-0">
            <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
                <a class="page-link border-0" asp-route-PageNumber="@(Model.PageNumber - 1)" asp-route-SearchTerm="@Model.SearchTerm" asp-route-PageSize="@Model.PageSize">
                    <i class="fas @(isRtl ? "fa-chevron-right" : "fa-chevron-left")"></i>
                </a>
            </li>
            @for (int i = 1; i <= Model.Section.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link border-0 mx-1" asp-route-PageNumber="@i" asp-route-SearchTerm="@Model.SearchTerm" asp-route-PageSize="@Model.PageSize">@i</a>
                </li>
            }
            <li class="page-item @(Model.PageNumber == Model.Section.TotalPages ? "disabled" : "")">
                <a class="page-link border-0" asp-route-PageNumber="@(Model.PageNumber + 1)" asp-route-SearchTerm="@Model.SearchTerm" asp-route-PageSize="@Model.PageSize">
                    <i class="fas @(isRtl ? "fa-chevron-left" : "fa-chevron-right")"></i>
                </a>
            </li>
        </ul>
    </nav>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmDelete(id) {
            Swal.fire({
                title: '@L["هل أنت متأكد؟"]',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                confirmButtonText: '@L["نعم، احذف!"]',
                cancelButtonText: '@L["إلغاء"]'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('delete-form-' + id).submit();
                }
            })
        }
    </script>
}